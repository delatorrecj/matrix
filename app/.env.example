# MATRIX app environment — copy to .env and fill. NEVER commit .env (CLR-matrix).

# --- Gemini (google-genai SDK) — verify model IDs at ai.google.dev. Never 1.5/2.0. ---
GOOGLE_API_KEY=
GEMINI_MODEL_PRO=gemini-3.1-pro          # orchestration + synthesis (confirm exact ID)
GEMINI_MODEL_FLASH_LITE=gemini-3.1-flash-lite  # persona generation (confirm exact ID)

# --- Datastores (Phase 0 = local; Phase 4 = cloud) ---
DATABASE_URL=postgresql://localhost:5432/matrix   # Supabase Postgres + PostGIS
REDIS_URL=redis://localhost:6379                   # persona pool + baseline + delta cache
CHROMA_PATH=./.chroma                              # local GraphRAG vector store

# --- Frontend ---
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000

# --- Iloilo pilot bbox (city proper) ---
ILOILO_BBOX=10.65,122.50,10.78,122.61
