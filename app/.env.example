# MATRIX app environment — copy to .env and fill. NEVER commit .env (CLR-matrix; see /SECURITY.md).
# Variable names below match what the code actually reads (grep-verified 2026-06-10).

# --- Gemini (google-genai SDK) — verify model IDs at ai.google.dev. Never 1.5/2.0. ---
GOOGLE_API_KEY=                                   # picked up by genai.Client() (orchestrator.py, synthesis.py, personas.py)
GEMINI_MODEL_PRO=gemini-3.1-pro                   # orchestration + synthesis (orchestrator.py, synthesis.py)
GEMINI_MODEL_FLASH_LITE=gemini-3.1-flash-lite     # persona generation (personas.py)

# --- Datastores (local dev = `docker compose up -d` in app/; prod = Fly/Supabase) ---
MATRIX_REDIS_URL=redis://localhost:6379/0         # baseline + persona pool + scenario cache (baseline.py, personas.py, apps/api/matrix_api/main.py; prod value set in fly.toml)
MATRIX_PG_DSN=postgresql://matrix:matrix@localhost:5432/matrix   # bias-audit log, Postgres+PostGIS (bias_auditor.py; matches docker-compose.yml)
DATABASE_URL=postgresql://matrix:matrix@localhost:5432/matrix    # API run/scenario persistence (matrix_api/db.py; matches docker-compose); unreachable -> in-memory fallback
CHROMA_PATH=./.chroma                             # GraphRAG embedded mode (graphrag.py)
CHROMA_URL=                                       # GraphRAG server mode, e.g. http://localhost:8001 — leave empty for embedded (graphrag.py)

# --- Frontend (apps/web) ---
# NOTE: the web app does not read these yet — the WS URL is hardcoded to ws://localhost:8000
# in src/app/scenario/[id]/page.tsx and the map uses a keyless OpenFreeMap MapLibre style.
# NEXT_PUBLIC_API_WS_URL is already set for prod in apps/web/vercel.json; wire-up pending.
NEXT_PUBLIC_API_WS_URL=ws://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=                         # only needed if/when switching to a Mapbox style

# --- City pilot (engine stays city-agnostic; MATRIX.md §6) ---
MATRIX_CITY_SLUG=iloilo

# --- Iloilo pilot bbox (city proper) ---
# Informational: build_network.py currently hardcodes this bbox (NET_PROVENANCE); kept here
# as the single place to look it up until it is wired as a parameter.
ILOILO_BBOX=10.65,122.50,10.78,122.61

# --- Multi-city kernel config (matrix_kernel/config.py; unset = Iloilo pilot) ---
# Precedence: env vars > MATRIX_CITY_CONFIG file > Iloilo defaults. Set BEFORE the
# kernel imports (baseline.py/personas.py bind constants at import time).
# MATRIX_CITY=Iloilo City                  # display name; slug auto-derived
# MATRIX_CITY_SLUG=iloilo                  # Redis keys: baseline:{slug}:latest, personas:{slug}:v1
# MATRIX_NET_PATH=packages/kernel/data/iloilo.net.xml
# MATRIX_ROU_PATH=packages/kernel/data/iloilo.rou.xml
# MATRIX_BBOX=10.65,122.50,10.78,122.61    # lat_min,lon_min,lat_max,lon_max
# MATRIX_MODE_SHARE={"jeepney":0.55,"private_car":0.15,"motorcycle":0.15,"walk":0.10,"bicycle":0.05}  # JSON, sums to ~1.0 (bias-audit anchor — document its source)
# MATRIX_CITY_CONFIG=./city.toml           # JSON/TOML per-city file; env vars override it

# --- Deploy tooling (optional, local CLI only) ---
# Prefer `fly secrets set` / Vercel project env vars / GitHub Actions secrets. If you keep
# CLI tokens here for local use, remember this file's copy (.env) is gitignored — keep it that way.
VERCEL_TOKEN=
FLY_API_TOKEN=
